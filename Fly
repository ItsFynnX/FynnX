local s_char = string.char
local m_random = math.random
local t_wait = task.wait
local t_spawn = task.spawn
local t_defer = task.defer
local t_insert = table.insert
local t_clear = table.clear
local i_new = Instance.new
local c3_rgb = Color3.fromRGB
local ud2_new = UDim2.new
local ud_new = UDim.new
local v3_new = Vector3.new
local cf_new = CFrame.new

-- Kỹ thuật sao chép hàm & tham chiếu bảo mật (Ghosting)
local clr = cloneref or function(i) return i end
local clf = clonefunction or function(f) return f end
local ncc = newcclosure or function(f) return f end

local get_serv = clf(game.GetService)

-- 2. BYTECODE OBFUSCATION (Giải mã dãy số thành từ khóa ẩn)
local function B(arr)
    local str = ""
    for i = 1, #arr do str = str .. s_char(arr[i]) end
    return str
end

-- Lấy Service bằng dãy số (Chống Static Scan)
local Players = clr(get_serv(game, B({80, 108, 97, 121, 101, 114, 115}))) -- "Players"
local RunService = clr(get_serv(game, B({82, 117, 110, 83, 101, 114, 118, 105, 99, 101}))) -- "RunService"
local UserInputService = clr(get_serv(game, B({85, 115, 101, 114, 73, 110, 112, 117, 116, 83, 101, 114, 118, 105, 99, 101}))) -- "UserInputService"
local CoreGui = clr(get_serv(game, B({67, 111, 114, 101, 71, 117, 105}))) -- "CoreGui"

-- 3. BỘ TẠO ID SIÊU CẤP & SECURE CALL
local function _ID_GEN()
    local charset = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    local res = ""
    for i = 1, 16 do
        local rand = m_random(1, #charset)
        res = res .. string.sub(charset, rand, rand)
    end
    return res
end

local SECURE_ID = _ID_GEN()
local LP = clr(Players.LocalPlayer)

local SecureCall = ncc(function(func, ...)
    local success, err = pcall(func, ...)
    return success
end)

-- BIẾN LOGIC FLY GỐC & BỘ NHỚ ĐỆM (CACHE)
local flying = false
local bv
local charParts = {}      -- Bộ nhớ đệm lưu các bộ phận nhân vật
local dynamicConnection   -- Lắng nghe nếu nhân vật cầm thêm Tool mới khi đang bay

-- Hàm cập nhật bộ nhớ đệm nhân vật (Chỉ chạy 1 lần khi bật)
local function CacheCharacterParts(char)
    t_clear(charParts)
    if not char then return end
    local desc = char:GetDescendants()
    local basepart_str = B({66, 97, 115, 101, 80, 97, 114, 116}) -- "BasePart"
    for i = 1, #desc do
        local v = desc[i]
        if v:IsA(basepart_str) then
            t_insert(charParts, v)
        end
    end
end

