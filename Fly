-- 5. HỆ THỐNG KÉO THẢ BẢO MẬT (Đã bọc C-Closure)
local dragging, dragInput, dragStart, startPos
Main.InputBegan:Connect(ncc(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end))

Main.InputChanged:Connect(ncc(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        dragInput = input
    end
end))

UserInputService.InputChanged:Connect(ncc(function(input)
    if dragging and input == dragInput then
        local delta = input.Position - dragStart
        Main.Position = ud2_new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end))

-- 6. LOGIC FLY SIÊU TỐI ƯU FPS
ToggleBtn.MouseButton1Click:Connect(ncc(function()
    SecureCall(function()
        flying = not flying
        local char = LP.Character
        local hrp_str = B({72, 117, 109, 97, 110, 111, 105, 100, 82, 111, 111, 116, 80, 97, 114, 116}) -- "HumanoidRootPart"
        local hum_str = B({72, 117, 109, 97, 110, 111, 105, 100}) -- "Humanoid"
        local basepart_str = B({66, 97, 115, 101, 80, 97, 114, 116}) -- "BasePart"

        if not char or not char:FindFirstChild(hrp_str) then return end
        local root = char:FindFirstChild(hrp_str)
        local hum = char:FindFirstChildOfClass(hum_str)

        if flying then
            ToggleBtn.Text = "ON"
            ToggleBtn.TextColor3 = c3_rgb(0, 255, 127)
            
            bv = i_new("BodyVelocity", root)
            bv.MaxForce = v3_new(9e9, 9e9, 9e9)
            hum.PlatformStand = true
            
            -- [TỐI ƯU CHÍ MẠNG]: Quét và lưu bộ nhớ đệm trước khi vào vòng lặp
            CacheCharacterParts(char)
            
            -- Lắng nghe động: Nếu cầm thêm vũ khí/vật phẩm mới lúc đang bay, tự thêm vào cache
            dynamicConnection = char.DescendantAdded:Connect(ncc(function(v)
                if v:IsA(basepart_str) then
                    t_insert(charParts, v)
                end
            end))
            
            t_spawn(ncc(function()
                while flying do
                    local cam = workspace.CurrentCamera
                    local spd = tonumber(SpeedInput.Text) or 50
                    local moveDir = hum.MoveDirection
                    
                    -- [TỐI ƯU CHÍ MẠNG]: Chỉ lặp qua mảng lưu sẵn, không GetDescendants() nữa!
                    for i = 1, #charParts do
                        local part = charParts[i]
                        if part and part.Parent then
                            part.CanCollide = false
                        end
                    end

                    if moveDir.Magnitude > 0 then
                        local forwardInput = moveDir:Dot(cam.CFrame.LookVector)
                        local sideInput = moveDir:Dot(cam.CFrame.RightVector)
                        bv.Velocity = (cam.CFrame.LookVector * forwardInput + cam.CFrame.RightVector * sideInput).Unit * spd
                    else
                        bv.Velocity = v3_new(0, 0, 0)
                    end
                    
                    root.CFrame = cf_new(root.Position, root.Position + cam.CFrame.LookVector)
                    RunService.RenderStepped:Wait()
                end
            end))
        else
            ToggleBtn.Text = "OFF"
            ToggleBtn.TextColor3 = c3_rgb(255, 255, 255)
            
            if dynamicConnection then dynamicConnection:Disconnect() end
            if bv then bv:Destroy() end
            if hum then hum.PlatformStand = false end
            
            -- Khôi phục va chạm từ bộ nhớ đệm
            for i = 1, #charParts do
                local part = charParts[i]
                if part and part.Parent then
                    part.CanCollide = true
                end
            end
            t_clear(charParts) -- Giải phóng bộ nhớ RAM tạm
        end
    end)
end))

-- 7. ZERO MEMORY TRACE (Tự hủy script khỏi máy để tránh rác RAM)
t_defer(ncc(function()
    if script then script:Destroy() end
end))
