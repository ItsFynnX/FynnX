local function _ID_GEN()
    local charset = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    local res = ""
    for i = 1, 12 do
        local rand = m_random(1, #charset)
        res = res .. string.sub(charset, rand, rand)
    end
    return res
end

local SECURE_ID = _ID_GEN()
