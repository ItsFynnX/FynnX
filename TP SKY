local V3_ZERO = v3_new(0, 0, 0)

local SecureCall = ncc(function(func, ...)
    local success, err = pcall(func, ...)
    return success
end)

-- ==================== SAFE TELEPORT ====================
local function SafeTeleport(targetCFrame)
    local char = LP.Character
    if not char then return end
    
    SecureCall(function()
        local desc = char[getDescendants](char)
        for i = 1, #desc do
            local part = desc[i]
            if part[isA](part, CLASS_BASEPART) then
                part[PROP_ASLINEARVEL] = V3_ZERO
                part[PROP_ASANGULARVEL] = V3_ZERO
            end
        end
        char[METHOD_PIVOTTO](char, targetCFrame)
    end)
end

