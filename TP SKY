-- ==================== DRAG SYSTEM (CỰC HẠN) ====================
local dragInput = nil
local dragStartPos = nil
local dragStartMain = nil
local dragChangedConn = nil
local dragEndedConn = nil

local function stopDrag()
    if dragChangedConn then
        dragChangedConn[disconnect](dragChangedConn)
        dragChangedConn = nil
    end
    if dragEndedConn then
        dragEndedConn[disconnect](dragEndedConn)
        dragEndedConn = nil
    end
    dragInput = nil
    dragStartPos = nil
    dragStartMain = nil
end

local inputBeganSignal = Main.InputBegan
inputBeganSignal[connect](inputBeganSignal, ncc(function(input)
    if input.UserInputType == UIT_MOUSE1 or input.UserInputType == UIT_TOUCH then
        stopDrag()
        
        dragInput = input
        dragStartPos = input[PROP_POSITION]
        dragStartMain = Main[PROP_POSITION]
        
        local inputChangedSignal = input[changed]
        dragChangedConn = inputChangedSignal[connect](inputChangedSignal, ncc(function()
            if input.UserInputState == UIS_END then
                stopDrag()
            end
        end))
        
        local inputEndedSignal = UserInputService.InputEnded
        dragEndedConn = inputEndedSignal[connect](inputEndedSignal, ncc(function(endedInput)
            if endedInput == input then
                stopDrag()
            end
        end))
    end
end))

local inputChangedSignal = UserInputService.InputChanged
inputChangedSignal[connect](inputChangedSignal, ncc(function(input)
    if input == dragInput and (input.UserInputType == UIT_MOUSE_MOVE or input.UserInputType == UIT_TOUCH) then
        local delta = input[PROP_POSITION] - dragStartPos
        Main[PROP_POSITION] = ud2_new(
            dragStartMain.X.Scale,
            dragStartMain.X.Offset + delta.X,
            dragStartMain.Y.Scale,
            dragStartMain.Y.Offset + delta.Y
        )
    end
end))

