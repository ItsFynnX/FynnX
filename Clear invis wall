-- ===== DRAG TỐI ƯU =====
local dragInput = nil
local dragStartPos = nil
local dragStartMain = nil
local dragChangedConn = nil

local function stopDrag()
    if dragChangedConn then
        dragChangedConn[METHOD_DISCONNECT](dragChangedConn)
        dragChangedConn = nil
    end
    dragInput = nil
    dragStartPos = nil
    dragStartMain = nil
end

local inputBeganSignal = Main.InputBegan
inputBeganSignal[connect](inputBeganSignal, function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        stopDrag()
        dragInput = input
        dragStartPos = input[PROP_POSITION]
        dragStartMain = Main.Position
        local inputChangedSignal = input[changed]
        dragChangedConn = inputChangedSignal[connect](inputChangedSignal, function()
            if input.UserInputState == Enum.UserInputState.End then
                stopDrag()
            end
        end)
    end
end)

local inputChangedSignal = UserInputService.InputChanged
inputChangedSignal[connect](inputChangedSignal, function(input)
    if input == dragInput and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input[PROP_POSITION] - dragStartPos
        Main.Position = ud2_new(
            dragStartMain.X.Scale,
            dragStartMain.X.Offset + delta.X,
            dragStartMain.Y.Scale,
            dragStartMain.Y.Offset + delta.Y
        )
    end
end)

local inputEndedSignal = UserInputService.InputEnded
inputEndedSignal[connect](inputEndedSignal, function(input)
    if input == dragInput then
        stopDrag()
    end
end)

