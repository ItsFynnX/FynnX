-- ==================== BIẾN QUẢN LÝ ====================
local AntiWallEnabled = false
local wallStorage = {}
local charPartsSet = {}
local scanConnection = nil
local removeConnection = nil
local isProcessing = false
local updateConnection = nil
local lastProximityUpdate = 0

local COLOR_ON = c3_rgb(0, 255, 127)
local COLOR_OFF = c3_rgb(255, 255, 255)

local SecureCall = ncc(function(func, ...)
    local success, err = pcall(func, ...)
    return success
end)

-- Cập nhật danh sách các part của nhân vật (hashset)
local function UpdateCharPartsSet()
    t_clear(charPartsSet)
    local char = LP.Character
    if char then
        local desc = char[getDescendants](char)
        for i = 1, #desc do
            local p = desc[i]
            if p[isA](p, CLASS_BASEPART) then
                charPartsSet[p] = true
            end
        end
    end
end

-- Xử lý một part đơn lẻ
local function ProcessWall(part)
    if not part[isA](part, CLASS_BASEPART) then return end
    if charPartsSet[part] then return end
    if wallStorage[part] then return end
    
    if part[PROP_TRANSPARENCY] >= 1 and part[PROP_CANCOLLIDE] then
        wallStorage[part] = true
        part[PROP_CANCOLLIDE] = false
    end
end

-- TỐI ƯU CHÍNH: Quét theo bán kính xung quanh player
local function ScanNearbyParts(radius)
    local char = LP.Character
    if not char then return end
    
    local hrp = char[findFirstChild](char, "HumanoidRootPart")
    if not hrp then return end
    
    local pos = hrp[PROP_POSITION]
    local nearbyParts = wrkspace[getPartBoundsInRadius](wrkspace, pos, radius)
    
    for i = 1, #nearbyParts do
        ProcessWall(nearbyParts[i])
    end
end

-- Vòng lặp cập nhật liên tục khu vực xung quanh player
local function StartProximityUpdate()
    if updateConnection then
        updateConnection[METHOD_DISCONNECT](updateConnection)
    end
    
    updateConnection = heartbeat[connect](heartbeat, function()
        if not AntiWallEnabled then
            if updateConnection then
                updateConnection[METHOD_DISCONNECT](updateConnection)
                updateConnection = nil
            end
            return
        end
        
        -- Quét bán kính 100 stud mỗi 0.5 giây
        local currentTime = os.clock()
        if currentTime - lastProximityUpdate >= 0.3 then
            lastProximityUpdate = currentTime
            ScanNearbyParts(200)
        end
    end)
end

-- Bật Anti Wall
local function EnableAntiWall()
    if isProcessing then return end
    isProcessing = true
    
    UpdateCharPartsSet()
    
    if scanConnection then
        scanConnection[METHOD_DISCONNECT](scanConnection)
        scanConnection = nil
    end
    if removeConnection then
        removeConnection[METHOD_DISCONNECT](removeConnection)
        removeConnection = nil
    end
    
    -- Quét lần đầu toàn bộ workspace
    local descendants = wrkspace[getDescendants](wrkspace)
    local total = #descendants
    for i = 1, total do
        ProcessWall(descendants[i])
        if i % 600 == 0 then t_wait() end
    end
    
    -- Lắng nghe part mới xuất hiện
    scanConnection = wsDescendantAdded[connect](wsDescendantAdded, function(child)
        if AntiWallEnabled and not isProcessing then
            ProcessWall(child)
        end
    end)
    
    -- Dọn dẹp wallStorage khi part bị xóa
    removeConnection = wsDescendantRemoving[connect](wsDescendantRemoving, function(child)
        if wallStorage[child] then
            wallStorage[child] = nil
        end
    end)
    
    -- Bắt đầu quét proximity
    lastProximityUpdate = 0
    StartProximityUpdate()
    
    isProcessing = false
end

-- Tắt và khôi phục
local function DisableAntiWall()
    isProcessing = true
    
    if scanConnection then
        scanConnection[METHOD_DISCONNECT](scanConnection)
        scanConnection = nil
    end
    if removeConnection then
        removeConnection[METHOD_DISCONNECT](removeConnection)
        removeConnection = nil
    end
    if updateConnection then
        updateConnection[METHOD_DISCONNECT](updateConnection)
        updateConnection = nil
    end
    
    local count = 0
    for wall, _ in pairs(wallStorage) do
        if wall and wall[PROP_PARENT] then
            wall[PROP_CANCOLLIDE] = true
            count = count + 1
            if count % 300 == 0 then t_wait() end
        end
    end
    t_clear(wallStorage)
    
    isProcessing = false
end

-- Hàm toggle chính
local ToggleInvisibleWalls = ncc(function(state)
    if state == AntiWallEnabled then return end
    AntiWallEnabled = state
    if state then
        EnableAntiWall()
    else
        DisableAntiWall()
    end
end)

-- Khi nhân vật respawn
